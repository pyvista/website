---
import type { ThemedImage } from '../data/site';

interface Props {
  image: ThemedImage;
  alt: string;
  loading?: 'eager' | 'lazy';
  width?: number;
  height?: number;
}

const { image, alt, loading = 'lazy', width, height } = Astro.props;
---

<img
  src={image.dark}
  data-theme-media
  data-light-src={image.light}
  data-dark-src={image.dark}
  alt={alt}
  loading={loading}
  width={width}
  height={height}
/>
