---
interface Props {
  value: string;
  label?: string;
}

const { value, label = 'Copy' } = Astro.props;
---

<button
  class="copy-button"
  type="button"
  data-copy={value}
  data-copy-label={label}
  aria-label={label}
  title={label}
>
  <svg class="copy-icon copy-icon-copy" viewBox="0 0 24 24" aria-hidden="true">
    <rect x="9" y="9" width="10" height="10" rx="2"></rect>
    <path d="M7 15H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v1"></path>
  </svg>
  <svg class="copy-icon copy-icon-check" viewBox="0 0 24 24" aria-hidden="true">
    <path d="m5 12 4.2 4.2L19 6.5"></path>
  </svg>
  <span class="sr-only">{label}</span>
</button>
