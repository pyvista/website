---
import { navLinks } from '../data/site';
---

<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="#top" aria-label="PyVista home">
      <img class="brand-logo" src="/branding/pyvista.svg" alt="PyVista" />
    </a>

    <nav class="site-nav" aria-label="Primary">
      {navLinks.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <div class="header-actions">
      <a class="button button-secondary header-docs" href="https://docs.pyvista.org/">Docs</a>
      <button class="theme-toggle" type="button" aria-label="Toggle color theme" data-theme-toggle>
        <svg class="theme-icon theme-icon-sun" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 3.75a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V4.5a.75.75 0 0 1 .75-.75Zm0 12a3.75 3.75 0 1 0 0-7.5 3.75 3.75 0 0 0 0 7.5Zm8.25-4.5a.75.75 0 0 1 0 1.5h-1.5a.75.75 0 0 1 0-1.5h1.5ZM6.75 12a.75.75 0 0 1-.75.75H4.5a.75.75 0 0 1 0-1.5H6a.75.75 0 0 1 .75.75Zm9.614 5.114a.75.75 0 0 1 1.061 1.061l-1.06 1.061a.75.75 0 1 1-1.062-1.06l1.061-1.062Zm-8.728 0 1.06 1.061a.75.75 0 1 1-1.06 1.061l-1.061-1.06a.75.75 0 1 1 1.06-1.062Zm8.728-10.228a.75.75 0 0 1 0 1.06l-1.06 1.062a.75.75 0 1 1-1.062-1.06l1.061-1.062a.75.75 0 0 1 1.061 0Zm-8.728 0 1.06 1.06a.75.75 0 1 1-1.06 1.062L6.575 7.946a.75.75 0 1 1 1.06-1.06ZM12 18a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 12 18Z"
            fill="currentColor"></path>
        </svg>
        <svg class="theme-icon theme-icon-moon" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M14.53 2.47a.75.75 0 0 1 .81.18 9.75 9.75 0 1 0 6.01 8.94.75.75 0 0 1 1.2-.6 1.5 1.5 0 0 1 .42.98c0 6.21-5.04 11.25-11.25 11.25S.47 18.18.47 11.97 5.51.72 11.72.72c.33 0 .66.02.98.07a.75.75 0 0 1 .61 1.18 8.24 8.24 0 0 0 1.22.5Z"
            fill="currentColor"></path>
        </svg>
      </button>
    </div>
  </div>
</header>
