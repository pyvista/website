---
import { codeToHtml } from 'shiki';

import CopyButton from '../components/CopyButton.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ThemeImage from '../components/ThemeImage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  citation,
  exampleGallery,
  ecosystemProjects,
  exampleSpotlight,
  kitchenSpotlight,
  bunnySpotlight,
  featureCards,
  hero,
  heroScreenshots,
  numfocus,
  resourceCards,
  trustBadges,
} from '../data/site';

const basicSnippet = `import pyvista as pv
from pyvista import examples

# or pv.read('path/to/mesh.obj')
mesh = examples.download_aero_bracket()
mesh.plot()`;

const kitchenSnippet = `import pyvista as pv
from pyvista import examples

# Kitchen CFD simulation: grid with a velocity field
# and furniture meshes as a separate dataset
mesh = examples.download_kitchen()
furniture = examples.download_kitchen(split=True)

# Trace streamlines from above the stove
source = pv.Line((0.08, 2.5, 0.71), (0.08, 4.5, 0.71), resolution=15)
streamlines = mesh.streamlines_from_source(source, max_length=200)

# Compose the scene
pl = pv.Plotter()
pl.add_mesh(furniture, color='slategray')
pl.add_mesh(streamlines.tube(radius=0.02))
pl.show()`;

const vtkSnippet = `import vtk

reader = vtk.vtkSTLReader()
reader.SetFileName('bunny.stl')
mapper = vtk.vtkDataSetMapper()
mapper.SetInputConnection(reader.GetOutputPort())
actor = vtk.vtkActor()
actor.SetMapper(mapper)
ren = vtk.vtkRenderer()
ren.AddActor(actor)
renWin = vtk.vtkRenderWindow()
renWin.AddRenderer(ren)
iren = vtk.vtkRenderWindowInteractor()
iren.SetRenderWindow(renWin)
iren.SetInteractorStyle(vtk.vtkInteractorStyleTrackballCamera())
iren.Initialize()
renWin.Render()
iren.Start()`;

const pyvistaSnippet = `import pyvista as pv

mesh = pv.read('bunny.stl')
mesh.plot()`;

const shikiOpts = { lang: 'python', theme: 'github-dark' } as const;
const basicHtml = await codeToHtml(basicSnippet, shikiOpts);
const kitchenHtml = await codeToHtml(kitchenSnippet, shikiOpts);
const vtkHtml = await codeToHtml(vtkSnippet, shikiOpts);
const pyvistaHtml = await codeToHtml(pyvistaSnippet, shikiOpts);

type Contributor = {
  login: string;
  avatar_url: string;
  html_url: string;
  type: string;
  contributions: number;
};

let contributors: Contributor[] = [];
try {
  const headers: Record<string, string> = {
    Accept: 'application/vnd.github+json',
    'User-Agent': 'pyvista-website-build',
  };
  if (process.env.GITHUB_TOKEN) {
    headers.Authorization = `Bearer ${process.env.GITHUB_TOKEN}`;
  }
  const response = await fetch(
    'https://api.github.com/repos/pyvista/pyvista/contributors?per_page=100',
    { headers },
  );
  if (response.ok) {
    const payload = (await response.json()) as Contributor[];
    contributors = payload.filter((c) => c.type !== 'Bot' && !c.login.endsWith('[bot]'));
  } else {
    console.warn(`GitHub contributors API returned ${response.status}`);
  }
} catch (error) {
  console.warn('Failed to fetch contributors:', error);
}

type CitingWork = {
  id: string;
  doi: string | null;
  display_name: string;
  publication_year: number;
  cited_by_count: number;
  authorships: { author: { display_name: string } }[];
  primary_location?: { source?: { display_name?: string } | null } | null;
};

const OPENALEX_WORK_ID = 'W2945475836';
const OPENALEX_UA = 'pyvista-website-build (mailto:info@pyvista.org)';
let citationCount: number | null = null;
let topCitations: CitingWork[] = [];
try {
  const workResponse = await fetch(`https://api.openalex.org/works/${OPENALEX_WORK_ID}`, {
    headers: { 'User-Agent': OPENALEX_UA },
  });
  if (workResponse.ok) {
    const payload = (await workResponse.json()) as { cited_by_count: number };
    citationCount = payload.cited_by_count;
  } else {
    console.warn(`OpenAlex work API returned ${workResponse.status}`);
  }

  const citingUrl = new URL('https://api.openalex.org/works');
  citingUrl.searchParams.set('filter', `cites:${OPENALEX_WORK_ID}`);
  citingUrl.searchParams.set('per-page', '5');
  citingUrl.searchParams.set('sort', 'cited_by_count:desc');
  citingUrl.searchParams.set(
    'select',
    'id,doi,display_name,publication_year,cited_by_count,authorships,primary_location',
  );
  const citingResponse = await fetch(citingUrl.toString(), {
    headers: { 'User-Agent': OPENALEX_UA },
  });
  if (citingResponse.ok) {
    const payload = (await citingResponse.json()) as { results: CitingWork[] };
    topCitations = payload.results;
  } else {
    console.warn(`OpenAlex citing API returned ${citingResponse.status}`);
  }
} catch (error) {
  console.warn('Failed to fetch OpenAlex data:', error);
}

// Keep the "Python 3.10+" badge in sync with the live pyproject requirement on
// PyPI so it never drifts out of date when the minimum supported version
// changes in a release.
let pythonMinVersion = '3.10';
try {
  const response = await fetch('https://pypi.org/pypi/pyvista/json');
  if (response.ok) {
    const payload = (await response.json()) as { info: { requires_python?: string } };
    const match = payload.info.requires_python?.match(/(\d+\.\d+)/);
    if (match) pythonMinVersion = match[1];
  } else {
    console.warn(`PyPI API returned ${response.status}`);
  }
} catch (error) {
  console.warn('Failed to fetch PyPI metadata:', error);
}

const resolvedTrustBadges = trustBadges.map((badge) =>
  badge.id === 'python' ? { ...badge, label: `Python ${pythonMinVersion}+` } : badge,
);

const formatAuthors = (authorships: CitingWork['authorships']) => {
  const names = authorships
    .map((a) => a.author?.display_name)
    .filter((n): n is string => Boolean(n))
    .slice(0, 3);
  if (authorships.length > names.length) names.push('et al.');
  return names.join(', ');
};
---

<BaseLayout>
  <main id="content">
    <section class="hero section section-tinted" id="top">
      <div class="container hero-shell">
        <div class="hero-topcards">
          <div class="hero-head">
            <h1>
              {hero.title}
              <em>{hero.titleEmphasis}</em>
            </h1>
            <p class="hero-mission">{hero.mission}</p>
          </div>

          <div class="install-strip">
            <div class="install-inline">
              <span class="install-label">Quick install</span>
              <code class="install-command">{hero.installCommand}</code>
            </div>
            <CopyButton value={hero.installCommand} />
          </div>
        </div>

        <div class="hero-utility-row">
          <div class="hero-actions-row">
            <div class="button-row">
              <a
                class="button button-secondary hero-icon-button"
                href="https://docs.pyvista.org/"
                aria-label="Read the documentation"
                title="Read the documentation"
              >
                <svg class="hero-button-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path
                    d="M7.5 3.75h6.75L18.75 8.25V18A2.25 2.25 0 0 1 16.5 20.25h-9A2.25 2.25 0 0 1 5.25 18V6A2.25 2.25 0 0 1 7.5 3.75Z"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M14.25 3.75V8.25h4.5"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M9 12h6"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                  <path
                    d="M9 15.75h6"
                    stroke="currentColor"
                    stroke-width="1.8"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </a>
              <a
                class="button button-secondary hero-icon-button"
                href="https://github.com/pyvista/pyvista"
                aria-label="View on GitHub"
                title="View on GitHub"
              >
                <svg
                  class="hero-button-icon hero-button-icon-fill"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 0 0 7.86 10.92c.58.1.79-.25.79-.56v-1.98c-3.2.7-3.88-1.54-3.88-1.54-.52-1.34-1.28-1.69-1.28-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.75 1.18 1.75 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.72-1.52-2.55-.29-5.23-1.27-5.23-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.47.11-3.06 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.63 1.59.24 2.77.12 3.06.74.8 1.18 1.83 1.18 3.08 0 4.41-2.68 5.37-5.24 5.65.41.35.77 1.04.77 2.11v3.12c0 .31.21.67.8.56A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
                  ></path>
                </svg>
              </a>
            </div>

            <div class="badge-list">
              {
                resolvedTrustBadges.map((item) => (
                  <a class="badge-link" href={item.href}>
                    {item.label}
                  </a>
                ))
              }
            </div>
          </div>
        </div>

        <div class="hero-media-grid" aria-label="Featured PyVista screenshots">
          {
            heroScreenshots.map((shot, index) => (
              <figure class="hero-shot">
                <a class="visual-link" href={shot.href}>
                  <ThemeImage
                    image={shot.image}
                    alt={shot.alt}
                    loading={index === 0 ? 'eager' : 'lazy'}
                  />
                  <figcaption>{shot.label}</figcaption>
                </a>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="why-pyvista">
      <div class="container">
        <div class="section-header section-header-trust">
          <div class="section-header-trust-text">
            <h2>The 3D library that fits in with the rest of your Python stack.</h2>
            <p>
              PyVista brings 3D data, mesh analysis, and plotting into the same idiom as NumPy,
              pandas, and xarray. Array-native datasets, direct memory sharing where possible, and
              an interface that reads the way your research code already does.
            </p>
          </div>
          <a class="numfocus-lockup numfocus-lockup-inline" href={numfocus.href}>
            <img src={numfocus.image} alt={numfocus.alt} loading="lazy" />
            <span class="numfocus-tag">Affiliated</span>
          </a>
        </div>

        <div class="card-grid feature-grid">
          {
            featureCards.map((card) => (
              <article class="content-card accent-card">
                <p class="card-eyebrow">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-tinted" id="example">
      <div class="container">
        <SectionHeader
          eyebrow="Example"
          title="Declarative 3D in Python."
          intro="Describe what you want to see and PyVista builds the scene, manages GPU resources, and cleans up when the window closes."
        />

        <div class="example-tabs" data-example-tabs>
          <div class="example-tab-list" role="tablist" aria-label="Example snippets">
            <button
              class="example-tab"
              type="button"
              role="tab"
              data-tab="basic"
              aria-selected="true"
            >
              Basic
            </button>
            <button
              class="example-tab"
              type="button"
              role="tab"
              data-tab="kitchen"
              aria-selected="false"
            >
              Kitchen airflow
            </button>
            <button
              class="example-tab"
              type="button"
              role="tab"
              data-tab="comparison"
              aria-selected="false"
            >
              Comparison
            </button>
          </div>

          <div class="example-tab-panel" role="tabpanel" data-tab="basic">
            <div class="section-split example-top-grid">
              <article class="code-panel example-panel">
                <div class="panel-topline">
                  <span>Python</span>
                  <CopyButton value={basicSnippet} />
                </div>
                <div class="code-block" set:html={basicHtml} />
              </article>

              <figure class="feature-visual">
                <a class="visual-link" href={exampleSpotlight.href}>
                  <ThemeImage
                    image={exampleSpotlight.image}
                    alt={exampleSpotlight.alt}
                    loading="lazy"
                  />
                  <figcaption>{exampleSpotlight.label}</figcaption>
                </a>
              </figure>
            </div>
          </div>

          <div class="example-tab-panel" role="tabpanel" data-tab="kitchen" hidden>
            <div class="section-split example-top-grid">
              <article class="code-panel example-panel">
                <div class="panel-topline">
                  <span>Python</span>
                  <CopyButton value={kitchenSnippet} />
                </div>
                <div class="code-block" set:html={kitchenHtml} />
              </article>

              <figure class="feature-visual">
                <a class="visual-link" href={kitchenSpotlight.href}>
                  <ThemeImage
                    image={kitchenSpotlight.image}
                    alt={kitchenSpotlight.alt}
                    loading="lazy"
                  />
                  <figcaption>{kitchenSpotlight.label}</figcaption>
                </a>
              </figure>
            </div>
          </div>

          <div class="example-tab-panel" role="tabpanel" data-tab="comparison" hidden>
            <p class="example-comparison-caption">
              Reading and plotting an STL file in low-level Python graphics code versus PyVista.
              Same result, a fraction of the work.
            </p>
            <div class="example-comparison-grid">
              <article class="code-panel example-panel">
                <div class="panel-topline">
                  <span>Low-level graphics code</span>
                  <CopyButton value={vtkSnippet} />
                </div>
                <div class="code-block" set:html={vtkHtml} />
              </article>

              <div class="example-comparison-pyvista">
                <article class="code-panel example-panel">
                  <div class="panel-topline">
                    <span>PyVista</span>
                    <CopyButton value={pyvistaSnippet} />
                  </div>
                  <div class="code-block" set:html={pyvistaHtml} />
                </article>

                <figure class="feature-visual">
                  <a class="visual-link" href={bunnySpotlight.href}>
                    <ThemeImage
                      image={bunnySpotlight.image}
                      alt={bunnySpotlight.alt}
                      loading="lazy"
                    />
                    <figcaption>{bunnySpotlight.label}</figcaption>
                  </a>
                </figure>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="explore">
      <div class="container">
        <SectionHeader
          eyebrow="Explore PyVista"
          title="The docs are the best place to go deeper."
          intro="Whether you're installing PyVista for the first time, browsing the gallery, or reaching for an API reference, the documentation has what you need."
        />

        <div class="card-grid resource-card-grid">
          {
            resourceCards.map((item) => (
              <article class="content-card link-card resource-card">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
                <a class="card-action" href={item.href}>
                  {item.cta}
                </a>
              </article>
            ))
          }
        </div>

        <div class="card-grid example-gallery-grid">
          {
            exampleGallery.map((item) => (
              <figure class="feature-visual">
                <a class="visual-link" href={item.href}>
                  <ThemeImage image={item.image} alt={item.alt} loading="lazy" />
                  <figcaption>{item.label}</figcaption>
                </a>
              </figure>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-tinted" id="ecosystem">
      <div class="container">
        <SectionHeader
          eyebrow="Ecosystem"
          title="Projects built on PyVista."
          intro="Official projects extend PyVista with mesh repair, meshing, testing, and compression. Community projects build on it for neuroscience, deep learning on point clouds, geosciences, CFD, and more."
        />

        <div class="card-grid ecosystem-grid">
          {
            ecosystemProjects.map((project) => (
              <article class="content-card link-card project-card">
                <div class="project-header">
                  <h3>{project.name}</h3>
                  <span class={`status-pill status-${project.kind}`}>{project.badge}</span>
                </div>
                <p>{project.description}</p>
                <div class="card-link-row">
                  <a class="card-action" href={project.href}>
                    Project
                  </a>
                  {project.secondaryHref && (
                    <a class="card-action card-action-muted" href={project.secondaryHref}>
                      {project.secondaryLabel}
                    </a>
                  )}
                </div>
              </article>
            ))
          }
        </div>

        <div class="button-row button-row-compact section-actions">
          <a
            class="button button-secondary"
            href="https://docs.pyvista.org/getting-started/connections.html"
          >
            Explore more connections
          </a>
        </div>
      </div>
    </section>

    {
      contributors.length > 0 && (
        <section class="section" id="contributors">
          <div class="container">
            <SectionHeader
              eyebrow="Contributors"
              title="Built in the open by a global community."
              intro="PyVista is developed and maintained by contributors from around the world. Thanks to everyone who has helped shape the project."
            />
            <ul class="contributor-grid" aria-label="PyVista contributors">
              {contributors.map((c) => (
                <li>
                  <a
                    class="contributor-link"
                    href={c.html_url}
                    title={`${c.login} · ${c.contributions} contributions`}
                    aria-label={c.login}
                  >
                    <img
                      src={`${c.avatar_url}&s=96`}
                      alt={c.login}
                      loading="lazy"
                      width="48"
                      height="48"
                    />
                  </a>
                </li>
              ))}
            </ul>
            <div class="button-row button-row-compact section-actions">
              <a
                class="button button-secondary"
                href="https://github.com/pyvista/pyvista/graphs/contributors"
              >
                See all contributors on GitHub
              </a>
            </div>
          </div>
        </section>
      )
    }

    <section class="section section-tinted" id="citation">
      <div class="container citation-section">
        <SectionHeader
          eyebrow="Cite & publications"
          title="Cited across the sciences."
          intro="PyVista shows up in published research across aerospace, geoscience, neuroscience, electrical engineering, and more. If it helps your work, please cite the JOSS paper so the project stays visible in the scientific record."
        />

        {
          citationCount !== null && (
            <div class="citation-stat">
              <div class="citation-stat-figure">
                <span class="citation-stat-number">{citationCount.toLocaleString()}</span>
                <span class="citation-stat-label">papers cite PyVista</span>
              </div>
              <a
                class="citation-stat-source"
                href={`https://openalex.org/works/${OPENALEX_WORK_ID}`}
              >
                Live count from OpenAlex
              </a>
            </div>
          )
        }

        <div class="citation-actions">
          <a class="button button-primary" href={citation.paper}>View the JOSS paper</a>
          <a class="button button-secondary" href={citation.doi}>Open DOI</a>
        </div>

        {
          topCitations.length > 0 && (
            <div class="citation-highlights">
              <h3>A few papers built on PyVista</h3>
              <ul>
                {topCitations.map((work) => {
                  const href = work.doi ?? work.id;
                  const venue = work.primary_location?.source?.display_name ?? 'Preprint';
                  return (
                    <li>
                      <a href={href}>{work.display_name}</a>
                      <p>
                        {formatAuthors(work.authorships)} · {venue} · {work.publication_year}
                      </p>
                    </li>
                  );
                })}
              </ul>
            </div>
          )
        }

        <div class="citation-stack">
          <article class="code-panel">
            <div class="panel-topline">
              <span>Citation</span>
              <div class="panel-topline-actions">
                <CopyButton value={citation.text} label="Copy text" showLabel />
                <CopyButton value={citation.bibtex} label="Copy BibTeX" showLabel />
              </div>
            </div>
            <pre class="plain-block"><code>{citation.text}</code></pre>
          </article>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
